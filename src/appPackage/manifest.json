{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.22/MicrosoftTeams.schema.json",
  "manifestVersion": "1.22",
  "version": "0.1.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "A365 Foundry",
    "websiteUrl": "https://example.com",
    "privacyUrl": "https://example.com/privacy",
    "termsOfUseUrl": "https://example.com/terms"
  },
  "name": {
    "short": "OperationsEngineering",
    "full": "OperationsEngineering Foundry Agent"
  },
  "description": {
    "short": "Proxy to the OperationsEngineering Azure AI Foundry agent.",
    "full": "A Microsoft 365 custom engine agent that proxies the OperationsEngineering Azure AI Foundry agent while preserving the Foundry orchestration boundary."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "bots": [
    {
      "botId": "${{BOT_ID}}",
      "scopes": ["personal", "team"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "copilotAgents": {
    "customEngineAgents": [
      {
        "id": "${{BOT_ID}}",
        "type": "bot"
      }
    ]
  },
  "validDomains": ["${{BOT_DOMAIN}}"],
  "webApplicationInfo": {
    "id": "${{BOT_ID}}",
    "resource": "api://botid-${{BOT_ID}}"
  },
  "authorization": {
    "permissions": {
      "resourceSpecific": []
    }
  }
}
